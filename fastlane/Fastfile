default_platform(:mac)

platform :mac do
  desc "Deploy to Mac App Store"
  lane :deploy do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_PRIVATE_KEY"],
      is_key_content_base64: false
    )

    build_mac_app(
      project: "Sift.xcodeproj",
      scheme: "Sift",
      export_method: "app-store",
      output_directory: "build",
      output_name: "Sift.pkg",
      xcargs: "CODE_SIGN_STYLE=Manual PROVISIONING_PROFILE_SPECIFIER='Sift App Store'"
    )

    upload_to_app_store(
      api_key: api_key,
      pkg: "build/Sift.pkg",
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false,
      force: true
    )
  end
end
