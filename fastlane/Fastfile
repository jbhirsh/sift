default_platform(:ios)

platform :ios do
  desc "Capture App Store screenshots via Fastlane Snapshot"
  lane :screenshots do
    require "json"
    require "fileutils"

    # Devices listed in Snapfile (source of truth for device selection)
    snapfile_devices = [
      "iPhone 17 Pro",
      "iPhone 17 Pro Max",
      "iPad Pro 13-inch (M5)"
    ]

    # Resolve device UDIDs from simctl — avoids the OS version mismatch that
    # occurs when the simulator runtime's marketing version (e.g. 26.3) differs
    # from the product version xcodebuild reports (e.g. 26.3.1). Passing UDIDs
    # directly bypasses the name+OS destination spec that capture_screenshots
    # generates and that xcodebuild cannot match in this situation.
    simctl = JSON.parse(`xcrun simctl list -j devices`)
    device_udids = []
    simctl["devices"].each do |runtime_id, devices|
      next unless runtime_id.include?("iOS")
      devices.each do |device|
        next unless device["isAvailable"] && snapfile_devices.include?(device["name"])
        device_udids << device["udid"]
      end
    end
    UI.user_error!("No simulators found matching: #{snapfile_devices}") if device_udids.empty?

    # Set up the Fastlane snapshot cache directory that SnapshotHelper reads
    # at runtime to discover language/locale and where to write PNGs.
    cache_dir = File.expand_path("~/Library/Caches/tools.fastlane")
    screenshots_cache = "#{cache_dir}/screenshots"
    FileUtils.mkdir_p(screenshots_cache)
    File.write("#{cache_dir}/language.txt", "en-US")
    File.write("#{cache_dir}/locale.txt", "en_US")
    File.write("#{cache_dir}/snapshot-launch_arguments.txt", "")
    Dir.glob("#{screenshots_cache}/*.png").each { |f| FileUtils.rm(f) }

    # Boot each simulator (no-op if already booted)
    device_udids.each do |udid|
      sh("xcrun simctl boot #{udid} 2>/dev/null || true")
    end

    # Run screenshot tests on all simulators simultaneously.
    # SnapshotHelper writes {SimulatorName}-{screenshotName}.png files into
    # screenshots_cache via XCUIScreen.main.screenshot().
    destinations = device_udids.map { |udid| "-destination 'platform=iOS Simulator,id=#{udid}'" }.join(" ")
    sh(
      "set -o pipefail && xcodebuild -scheme SiftScreenshots -project ../Sift.xcodeproj " \
      "#{destinations} " \
      "CODE_SIGNING_REQUIRED=NO CODE_SIGN_IDENTITY=- " \
      "ENABLE_USER_SCRIPT_SANDBOXING=NO " \
      "ASSETCATALOG_COMPILER_SKIP_APP_STORE_DEPLOYMENT=YES " \
      "FASTLANE_SNAPSHOT=YES FASTLANE_LANGUAGE=en-US " \
      "build test | xcbeautify"
    )

    # Collect PNGs into the output directory used by upload_to_app_store
    output_dir = "./screenshots/en-US"
    FileUtils.rm_rf("./screenshots")
    FileUtils.mkdir_p(output_dir)
    Dir.glob("#{screenshots_cache}/*.png").each { |f| FileUtils.cp(f, output_dir) }

    UI.success "Screenshots saved to #{output_dir}"
  end

  desc "Deploy to App Store"
  lane :deploy do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_PRIVATE_KEY"],
      is_key_content_base64: false
    )

    build_app(
      project: "Sift.xcodeproj",
      scheme: "Sift",
      export_method: "app-store",
      output_directory: "build",
      output_name: "Sift.ipa"
    )

    upload_to_app_store(
      api_key: api_key,
      ipa: "build/Sift.ipa",
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false,
      force: true
    )
  end
end
