default_platform(:ios)

platform :ios do
  desc "Capture App Store screenshots via Fastlane Snapshot"
  lane :screenshots do
    capture_screenshots
  end

  desc "Deploy to App Store"
  lane :deploy do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_PRIVATE_KEY"],
      is_key_content_base64: false
    )

    build_app(
      project: "Sift.xcodeproj",
      scheme: "Sift",
      export_method: "app-store",
      output_directory: "build",
      output_name: "Sift.ipa"
    )

    upload_to_app_store(
      api_key: api_key,
      ipa: "build/Sift.ipa",
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false,
      force: true
    )
  end
end
