default_platform(:mac)

platform :mac do
  desc "Collect App Store screenshots captured by the SiftScreenshots Xcode scheme"
  lane :screenshots do
    cache_dir = File.expand_path("~/Library/Caches/tools.fastlane/screenshots")
    output_dir = File.expand_path("../fastlane/screenshots/en-US", __dir__)
    pngs = Dir.glob("#{cache_dir}/**/*.png")

    if pngs.empty?
      UI.important("No screenshots found in cache.")
      UI.important("Run the SiftScreenshots scheme from Xcode first:")
      UI.important("  1. Select the 'SiftScreenshots' scheme in Xcode")
      UI.important("  2. Product → Test  (⌘U)")
      UI.important("  3. Then run 'fastlane screenshots' again to collect them")
      next
    end

    FileUtils.rm_rf(output_dir)
    FileUtils.mkdir_p(output_dir)
    pngs.each { |f| FileUtils.cp(f, output_dir) }
    UI.success("#{pngs.count} screenshots saved to #{output_dir}")
  end

  desc "Deploy to Mac App Store"
  lane :deploy do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_PRIVATE_KEY"],
      is_key_content_base64: false
    )

    build_mac_app(
      project: "Sift.xcodeproj",
      scheme: "Sift",
      export_method: "app-store",
      output_directory: "build",
      output_name: "Sift.pkg",
      xcargs: "CODE_SIGN_STYLE=Manual PROVISIONING_PROFILE_SPECIFIER='Sift App Store'"
    )

    upload_to_app_store(
      api_key: api_key,
      pkg: "build/Sift.pkg",
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false,
      force: true
    )
  end
end
