# Sift — environment variables
#
# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is gitignored, so it is where secrets belong for local runs.
# Variables prefixed with EXPO_PUBLIC_ are inlined into the app bundle by Expo.

# Sentry Data Source Name (DSN) for crash & error reporting.
# Find it in Sentry → Project Settings → Client Keys (DSN).
# Leave unset to disable Sentry reporting entirely.
EXPO_PUBLIC_SENTRY_DSN=

# Force the in-memory mock music provider instead of the native MusicKit
# module or Spotify (used by E2E simulator builds and web previews).
# Set to 1 to enable; leave unset for normal runs.
# EXPO_PUBLIC_USE_MOCK_PROVIDER=
